# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real API keys.

# Google Gemini API — get your key at https://aistudio.google.com/
GOOGLE_API_KEY=AIza...

# GCP Configuration (for Phase 2 deployment)
USE_GCS=false
STORAGE_BUCKET=sentinel
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json (not needed in Cloud Run)

# Confidence threshold for human review routing
CONFIDENCE_THRESHOLD=0.80
